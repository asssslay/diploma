{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@my-better-t-app/db": "workspace:*",
    "@my-better-t-app/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.8",
    "resend": "^6.10.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.8",
    "typescript": "catalog:"
  }
}
